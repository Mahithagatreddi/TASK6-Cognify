<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cognifyz | Secure Dashboard Workspace</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>body { background: linear-gradient(135deg, #f8fafc 0%, #cbd5e1 100%); min-height: 100vh; }</style>
</head>
<body class="d-flex flex-column">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4 shadow">
        <div class="container">
            <div class="d-flex align-items-center">
                <a class="navbar-brand fw-bold text-info" href="#">Cognifyz</a>
                <span class="text-secondary mx-2">|</span>
                <span class="text-light opacity-75 small">Session Identity: <strong class="text-info">@<%= username %></strong></span>
            </div>
            <a class="btn btn-sm btn-outline-danger" href="/logout">Revoke Token (Logout)</a>
        </div>
    </nav>

    <div class="container flex-grow-1">
        <div id="msgBox" class="alert d-none shadow-sm"></div>
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card p-4 bg-white rounded-4 border-0 shadow-sm">
                    <h5 class="fw-bold mb-3">🔒 Secured Asset Injection</h5>
                    <form id="assetForm" onsubmit="commitNewAsset(event)">
                        <div class="mb-3"><label class="form-label small fw-semibold">Client Name</label><input type="text" id="clientName" class="form-control" required></div>
                        <div class="mb-3"><label class="form-label small fw-semibold">Data Email Link</label><input type="email" id="contactEmail" class="form-control" required></div>
                        <div class="mb-3"><label class="form-label small fw-semibold">Cloud Tier Node</label><select id="resourceTier" class="form-select" required><option value="Standard">Standard Access Matrix</option><option value="Premium">Premium Scale Architecture</option><option value="Enterprise">Enterprise Dedicated Node</option></select></div>
                        <button type="submit" class="btn btn-dark w-100 py-2 fw-bold">Push To Encrypted Cluster</button>
                    </form>
                </div>
            </div>
            <div class="col-lg-8">
                <div class="card p-4 bg-white rounded-4 border-0 shadow-sm">
                    <h5 class="fw-bold mb-3">🛡️ Authorized Isolated Records Ledger</h5>
                    <div class="table-responsive">
                        <table class="table table-striped align-middle m-0">
                            <thead class="table-dark"><tr><th>Persistent ID</th><th>Client Node Name</th><th>Secure Mail Contact</th><th>Architecture Profile</th><th>Actions</th></tr></thead>
                            <tbody id="dbDataTarget"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <footer class="bg-white text-center py-4 border-top mt-5"><p class="text-muted mb-0 small">&copy; 2026 Cognifyz Technologies. All Rights Reserved.</p></footer>

    <script>
        document.addEventListener('DOMContentLoaded', fetchSecuredData);

        async function fetchSecuredData() {
            const target = document.getElementById('dbDataTarget');
            try {
                const stream = await fetch('/api/resources', { headers: { 'Accept': 'application/json' } });
                if (stream.status === 401) return window.location.href = '/login';
                const payload = await stream.json();
                if (payload.success && payload.data.length > 0) {
                    target.innerHTML = payload.data.map(item => `
                        <tr>
                            <td class="font-monospace fw-bold text-primary small">${item._id}</td>
                            <td class="fw-semibold">${item.clientName}</td>
                            <td class="text-secondary small">${item.contactEmail}</td>
                            <td><span class="badge bg-dark text-info">${item.resourceTier}</span></td>
                            <td><button class="btn btn-sm btn-danger fw-bold py-0.5" onclick="purgeAsset('${item._id}')">Delete</button></td>
                        </tr>
                    `).join('');
                } else {
                    target.innerHTML = `<tr><td colspan="5" class="text-center py-4 text-muted">No database properties allocated to your cluster node context yet.</td></tr>`;
                }
            } catch (err) { alert('Pipeline execution fault reading endpoints.'); }
        }

        async function commitNewAsset(e) {
            e.preventDefault();
            const bodyData = { clientName: document.getElementById('clientName').value, contactEmail: document.getElementById('contactEmail').value, resourceTier: document.getElementById('resourceTier').value };
            try {
                const pipe = await fetch('/api/resources', { method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }, body: JSON.stringify(bodyData) });
                if (pipe.status === 401) return window.location.href = '/login';
                const output = await pipe.json();
                if (output.success) {
                    document.getElementById('assetForm').reset();
                    showBanner("success", "🎉 Document cluster resource saved directly inside secure persistent collections.");
                    fetchSecuredData();
                }
            } catch(e) { showBanner("danger", "Failed posting asset."); }
        }

        async function purgeAsset(id) {
            if (!confirm("Are you sure you want to drop this asset from the database cluster?")) return;
            try {
                const req = await fetch(`/api/resources/${id}`, { method: 'DELETE', headers: { 'Accept': 'application/json' } });
                const res = await req.json();
                if (res.success) { showBanner("success", "🗑️ Document deleted successfully from your database collections."); fetchSecuredData(); }
            } catch (err) { alert('Deletion channel intercept failure.'); }
        }

        尖function showBanner(type, text) {
            const b = document.getElementById('msgBox'); b.className = `alert alert-${type} shadow-sm`; b.innerHTML = text; b.classList.remove('d-none');
            setTimeout(() => b.classList.add('d-none'), 4000);
        }
    </script>
</body>
</html>