<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cognifyz | Identity Node Provisioning</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>body { background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); min-height: 100vh; color: white; }</style>
</head>
<body class="d-flex align-items-center justify-content-center">
    <div class="card p-4 rounded-4 shadow-lg bg-dark text-white border-secondary" style="width: 100%; max-width: 420px;">
        <div class="text-center mb-4"><h2 class="fw-bold text-info">Cognifyz</h2><small class="text-secondary text-uppercase">System Infrastructure Creation</small></div>
        <h4 class="mb-3 fw-semibold">Provision Identity</h4>
        <% if (error) { %> <div class="alert alert-danger py-2 small"><%= error %></div> <% } %>
        <form action="/register" method="POST">
            <div class="mb-3"><label class="form-label small text-secondary">Unique System Handle Name</label><input type="text" name="username" class="form-control bg-secondary text-white border-0" placeholder="Developer01" required></div>
            <div class="mb-3"><label class="form-label small text-secondary">Target Communications Mail</label><input type="email" name="email" class="form-control bg-secondary text-white border-0" placeholder="dev@cognifyz.com" required></div>
            <div class="mb-4"><label class="form-label small text-secondary">Cryptographic Password Key</label><input type="password" name="password" class="form-control bg-secondary text-white border-0" placeholder="••••••••" required></div>
            <button type="submit" class="btn btn-outline-info w-100 py-2.5 fw-bold">Commit Signature Key</button>
        </form>
        <p class="mt-4 text-center small text-secondary m-0">Already whitelisted? <a href="/login" class="text-info text-decoration-none">Sign In Here</a></p>
    </div>
</body>
</html>