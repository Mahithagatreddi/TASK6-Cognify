<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cognifyz | Secure Gateway Integration</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>body { background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); min-height: 100vh; color: white; }</style>
</head>
<body class="d-flex align-items-center justify-content-center">
    <div class="card p-4 rounded-4 shadow-lg bg-dark text-white border-secondary" style="width: 100%; max-width: 420px;">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-info">Cognifyz</h2>
            <small class="text-secondary tracking-widest text-uppercase">Where Data Meets Intelligence</small>
        </div>
        <h4 class="mb-3 fw-semibold">Sign In Gate</h4>
        <% if (error) { %> <div class="alert alert-danger py-2 small"><%= error %></div> <% } %>
        <form action="/login" method="POST">
            <div class="mb-3"><label class="form-label small text-secondary">Registered Email Address</label><input type="email" name="email" class="form-control bg-secondary text-white border-0" placeholder="ops@domain.com" required></div>
            <div class="mb-4"><label class="form-label small text-secondary">Security Password</label><input type="password" name="password" class="form-control bg-secondary text-white border-0" placeholder="••••••••" required></div>
            <button type="submit" class="btn btn-info w-100 py-2.5 fw-bold text-dark">Authenticate Identity →</button>
        </form>
        <p class="mt-4 text-center small text-secondary m-0">Need account clearance? <a href="/register" class="text-info text-decoration-none">Register Identity</a></p>
    </div>
</body>
</html>